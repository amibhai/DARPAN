# DARPAN Environment Configuration Template
# Copy to .env before deploying: cp env.template .env
# Fill in all required values marked with <REQUIRED>
# =============================================================================

# ─── ANTHROPIC API ────────────────────────────────────────────────────────────
# Required for LLM-powered command emulation (custom_commands.py)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=<REQUIRED>

# ─── ELASTIC STACK ────────────────────────────────────────────────────────────
ELASTIC_VERSION=8.11.0

# Kibana external port (bound to 127.0.0.1 — use SSH tunnel or nginx proxy for external access)
KIBANA_PORT=5601

# ─── NETWORK ─────────────────────────────────────────────────────────────────
# Auto-detected at runtime, but can be overridden:
# DARPAN_HOST_IP=192.168.1.100

# Internal Docker network for DARPAN (must not conflict with your LAN)
DARPAN_SUBNET=172.20.0.0/24
DARPAN_GATEWAY=172.20.0.1

# ─── THREAT INTELLIGENCE APIs ─────────────────────────────────────────────────
# AbuseIPDB (free tier: 1000 queries/day)
# Register at: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=<OPTIONAL>

# Shodan API (only needed for full results; InternetDB is free without key)
SHODAN_API_KEY=<OPTIONAL>

# ─── ALERT WEBHOOK (Slack/Teams/Discord) ─────────────────────────────────────
# Slack: https://api.slack.com/messaging/webhooks
# Teams: Use Incoming Webhook connector URL
# Discord: Use Webhook URL from Server Settings -> Integrations
# Leave empty to disable webhook notifications
HONEYTOKEN_WEBHOOK_URL=<OPTIONAL>

# ─── DATA RETENTION ───────────────────────────────────────────────────────────
# Cowrie log retention in days (logs older than this are rotated out)
LOG_RETENTION_DAYS=90

# Elasticsearch index lifecycle: delete indices older than N days
ES_INDEX_MAX_AGE_DAYS=90

# ─── ML PIPELINE ─────────────────────────────────────────────────────────────
# How often to retrain the classifier (hours)
ML_RETRAIN_INTERVAL_HOURS=24

# Minimum sessions required before triggering ML analysis
ML_MIN_SESSIONS=50

# ─── LURE SYSTEM ─────────────────────────────────────────────────────────────
# How often to regenerate the polymorphic honeyfs (hours)
LURE_REFRESH_INTERVAL_HOURS=6

# Number of new honeytokens to add per refresh cycle
HONEYTOKEN_ROTATE_COUNT=3

# ─── CONTAINER RESOURCE LIMITS ────────────────────────────────────────────────
COWRIE_MEMORY_LIMIT=512m
COWRIE_CPU_LIMIT=0.5
ES_HEAP_SIZE=2g
LOGSTASH_HEAP_SIZE=512m
